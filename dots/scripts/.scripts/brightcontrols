#!/bin/dash
AMOUNT=5

case $1 in
    up)
        light -A $AMOUNT
        icon="ΎΔτ ΎΒλ"
        ;;
    down)
        light -U $AMOUNT
        icon="ΎΔτ ΎΒμ"
        ;;
    min)
        light -S 1
        icon="ΎΔτ ΎΒμ"
        ;;
    max)
        light -S 100
        icon="ΎΔτ ΎΒλ"
        ;;
esac

light=$(light)
notify-send -r 2 "$icon" "${light%\.*}"
