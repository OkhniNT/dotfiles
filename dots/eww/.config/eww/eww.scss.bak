@import "colors.scss";

$bg: rgba($background, 0.0);

*{
    all: unset;

    font-family: monospace;
    font-weight: 900;
}

window {
    background: $bg;
    color: $foreground;

    & > * {
        // padding: 20px 0px 20px 20px;
        padding: 10px;
        padding-right: 0;
    }

}

.time-bar {
    padding: 7px;
}


.space {
    padding-top: 10px;
}

.workspaces, .time, .network {
    background: $background;
    border: 3px solid $foreground;
    border-radius: 20px;
}

.workspaces {
    padding: 7px 6px 7px 6px;
    font-size: 15px;
}

.network {
    padding: 6px 4px 5px 4px;
    font-size: 16px;
}

.network-label {
    padding: 10px 0 10px 0;
    font-size: 14px;
}

.time {
    padding: 7px 6px 7px 6px;
    font-size: 13px;
}

